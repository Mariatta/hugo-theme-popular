    <item>
      <title>Meetup Runbooks</title>
      <link>https://example.com/runbooks/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://example.com/runbooks/</guid>
      <description>&lt;h2 id=&#34;1--book-a-venue&#34;&gt;1 · Book a venue&lt;/h2&gt;&#xA;&lt;p&gt;Lock the room before anything else, the date depends on it. See the handbook&amp;rsquo;s &lt;a href=&#34;https://example.com/handbook/&#34;&gt;venue criteria&lt;/a&gt; for what makes a good space.&lt;/p&gt;&#xA;&lt;div class=&#34;g-checklist&#34; data-key=&#34;rb-venue&#34;&gt;&#xA;  &lt;div class=&#34;g-checklist__head&#34;&gt;&#xA;    &lt;span&gt;Checklist&lt;/span&gt;&#xA;    &lt;span class=&#34;g-checklist__count&#34;&gt;0/7 done&lt;/span&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;ul&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Shortlist 2–3 possible venues from our host contacts.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Confirm capacity (20–40), step-free access and an accessible washroom.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Confirm the equipment and setup your format needs.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Agree the date, start/end time and who holds the key.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Visit or verify the room in person.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Get the host&amp;rsquo;s day-of phone number and building access details.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&#xA;      &lt;button class=&#34;g-check&#34; type=&#34;button&#34; role=&#34;checkbox&#34; aria-checked=&#34;false&#34;&gt;&#xA;        &lt;span class=&#34;g-check__box&#34;&gt;&lt;/span&gt;&#xA;        &lt;span class=&#34;g-check__label&#34;&gt;Send the host a written confirmation with date, time and headcount.&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/li&gt;&#xA;  &lt;/ul&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;2--line-up-a-session-host&#34;&gt;2 · Line up a session host&lt;/h2&gt;&#xA;&lt;p&gt;A confirmed venue makes it easy to invite a host. Remember: first-timers welcome, offer to help them prepare.&lt;/p&gt;</description>
    </item>
